<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/scrollRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@android:color/white"
    android:paddingBottom="20dp"
    tools:context=".Address_fill">

    <LinearLayout
        android:id="@+id/mainLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp"
        android:focusableInTouchMode="true">

        <!-- ================= ORDER SUMMARY ================= -->

        <TextView
            android:id="@+id/tvOrderSummary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/order_summary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="18dp"
            android:textColor="@android:color/black"
            android:layout_marginBottom="8dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvProductName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="@android:color/black"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvProductPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@android:color/black"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvQuantity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@android:color/black"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvTotalAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textColor="#079C20"
            android:textSize="16sp"
            android:layout_marginBottom="16dp" />

        <!-- ================= DELIVERY ADDRESS ================= -->

        <TextView
            android:id="@+id/tvDeliveryTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/delivery_address"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:id="@+id/layoutPreviousAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:orientation="vertical"
            android:padding="14dp"
            android:background="#F5F5F5"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvPrevName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvPrevPhone"
                android:textColor="@android:color/black"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/tvPrevAddress"
                android:textColor="@android:color/black"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/tvPrevPin"
                android:textColor="@android:color/black"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnUseAddress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Use Address"
                    android:backgroundTint="#079C20"
                    android:textColor="@android:color/white" />

                <Button
                    android:id="@+id/btnEditAddress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Edit"
                    android:layout_marginStart="12dp"
                    android:backgroundTint="#FFA000"
                    android:textColor="@android:color/white" />
            </LinearLayout>
        </LinearLayout>

        <!-- ================= ADDRESS INPUTS ================= -->

        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/full_name"
            android:background="@drawable/address_field"
            android:textColor="@color/black"
            android:textColorHint="#615E5E"
            android:inputType="textPersonName"
            android:padding="12dp"
            android:layout_marginBottom="10dp" />

        <EditText
            android:id="@+id/etPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/phone_number"
            android:background="@drawable/address_field"
            android:textColor="@color/black"
            android:textColorHint="#615E5E"
            android:inputType="phone"
            android:maxLength="10"
            android:padding="12dp"
            android:layout_marginBottom="10dp" />

        <EditText
            android:id="@+id/etAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/delivery_address"
            android:background="@drawable/address_field"
            android:textColor="@color/black"
            android:textColorHint="#615E5E"
            android:minLines="3"
            android:gravity="top"
            android:padding="12dp"
            android:layout_marginBottom="10dp" />

        <EditText
            android:id="@+id/etPin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/pin_code"
            android:background="@drawable/address_field"
            android:textColor="@color/black"
            android:textColorHint="#615E5E"
            android:inputType="number"
            android:maxLength="6"
            android:padding="12dp"
            android:layout_marginBottom="10dp" />

        <!-- ================= PAYMENT OPTION ================= -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/payment_method"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@android:color/black"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="6dp" />

        <Spinner
            android:id="@+id/spinnerPayment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:theme="@style/SpinnerBlackText"
            android:background="@drawable/address_field"
            android:padding="10dp"/>

        <LinearLayout
            android:id="@+id/layoutOnlinePayment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="12dp">

            <Button
                android:id="@+id/btnShowQr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/show_qr_code"
                android:layout_gravity="center"
                android:padding="12dp"
                android:backgroundTint="#18D527"
                android:textColor="@android:color/white" />

            <EditText
                android:id="@+id/etUtr"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/enter_transaction_id_utr"
                android:background="@drawable/address_field"
                android:textColor="@color/black"
                android:textColorHint="#615E5E"
                android:padding="12dp"
                android:layout_marginTop="10dp" />
        </LinearLayout>


        <Button
            android:id="@+id/btnSubmit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/submit"
            android:backgroundTint="#18D527"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:padding="14dp" />

    </LinearLayout>
</ScrollView>
