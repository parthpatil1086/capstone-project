<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background Image -->
    <ImageView
        android:id="@+id/bgImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/background_supplier"
        android:scaleType="centerCrop"
        android:adjustViewBounds="true" />

    <!-- Foreground Scrollable Form -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/btnSubmitRequest"
        android:padding="20dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_marginTop="60dp"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:elevation="10dp"
            android:layout_gravity="center_horizontal"
            android:clipToPadding="false">

            <!-- Title -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sugarcane_supplier_request"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#2E7D32"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="20dp" />

            <!-- Product Name -->
            <TextView
                android:text="@string/product_name"
                android:textColor="#1B5E20"
                android:textSize="16sp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <EditText
                android:id="@+id/etProductName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sugarcane"
                android:enabled="false"
                android:focusable="false"
                android:textColor="@android:color/black"
                android:background="@drawable/rounded_edittext"
                android:layout_marginBottom="20dp" />

            <!-- Area -->
            <TextView
                android:text="@string/area_of_field_in_acres"
                android:textColor="#1B5E20"
                android:textSize="16sp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <EditText
                android:id="@+id/etQuantity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/enter_area_e_g_5_acres"
                android:inputType="numberDecimal"
                android:textColorHint="#928B8B"
                android:textColor="@android:color/black"
                android:background="@drawable/rounded_edittext"
                android:layout_marginBottom="20dp" />

            <!-- Growth Months -->
            <TextView
                android:text="@string/growth_months"
                android:textColor="#1B5E20"
                android:textSize="16sp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <EditText
                android:id="@+id/etGrowthMonths"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/enter_months_e_g_10"
                android:inputType="number"
                android:textColorHint="#928B8B"
                android:textColor="@android:color/black"
                android:background="@drawable/rounded_edittext"
                android:layout_marginBottom="20dp" />

            <!-- Location -->
            <TextView
                android:text="@string/location_village_district"
                android:textColor="#1B5E20"
                android:textSize="16sp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <EditText
                android:id="@+id/etLocation"
                android:textColorHint="#928B8B"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/enter_village_city_district"
                android:textColor="@android:color/black"
                android:background="@drawable/rounded_edittext"
                android:layout_marginBottom="20dp" />

            <!-- Upload Photo -->
            <TextView
                android:text="Upload Field Photo"
                android:textColor="#1B5E20"
                android:textSize="16sp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- Selected Image Name -->
            <TextView
                android:id="@+id/tvSelectedImageName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No image selected"
                android:textColor="#555555"
                android:background="@drawable/rounded_edittext"
                android:padding="12dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnPickImage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Choose Image"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4CAF50"
                android:elevation="6dp"
                android:layout_marginBottom="30dp" />

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnSubmitRequest"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@+id/statusbtn"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"
        android:layout_marginBottom="6dp"
        android:text="@string/submit"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#4CAF50"
        android:elevation="10dp" />

    <!-- Status Button -->
    <Button
        android:id="@+id/statusbtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"
        android:layout_marginBottom="25dp"
        android:text="@string/view_status"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#4CAF50"
        android:elevation="10dp" />

</RelativeLayout>
