<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#E8F5E9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Card Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:layout_marginTop="40dp"
            android:background="@android:color/white"
            android:elevation="6dp"
            android:clipToOutline="true"
            android:outlineSpotShadowColor="#B2DFDB"
            android:layout_marginBottom="20dp"
            android:paddingBottom="30dp">

            <!-- Factory Logo and Name -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:id="@+id/factoryLogo"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/shree_swastik_default"
                    android:contentDescription="Factory Logo"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/factoryName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Shreesvastik Agro"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#1B5E20"/>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#C8E6C9"
                android:layout_marginBottom="16dp" />

            <!-- Supplier Name -->
            <TextView
                android:id="@+id/detailSupplierName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Supplier Name"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"
                android:layout_marginBottom="8dp" />

            <!-- Bill Number -->
            <TextView
                android:id="@+id/detailBillNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bill Number: N/A"
                android:textSize="16sp"
                android:textColor="#000000"
                android:layout_marginBottom="16dp"/>

            <!-- Details -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Date -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Date:"
                        android:textStyle="bold"
                        android:textColor="#2E7D32"
                        android:textSize="16sp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/detailDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="10 Dec 2025"
                        android:textSize="16sp"
                        android:textColor="#33691E"
                        android:layout_weight="2" />
                </LinearLayout>

                <!-- Quantity -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Quantity:"
                        android:textStyle="bold"
                        android:textColor="#2E7D32"
                        android:textSize="16sp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/detailQty"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="5"
                        android:textSize="16sp"
                        android:textColor="#33691E"
                        android:layout_weight="2" />
                </LinearLayout>

                <!-- Price/Unit -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Price/Unit:"
                        android:textStyle="bold"
                        android:textColor="#2E7D32"
                        android:textSize="16sp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/detailPrice"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="₹3500"
                        android:textSize="16sp"
                        android:textColor="#33691E"
                        android:layout_weight="2" />
                </LinearLayout>

                <!-- Total -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Total Amount:"
                        android:textStyle="bold"
                        android:textColor="#2E7D32"
                        android:textSize="16sp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/detailTotal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="₹17500"
                        android:textSize="16sp"
                        android:textColor="#33691E"
                        android:layout_weight="2" />
                </LinearLayout>

                <!-- Status -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Status:"
                        android:textStyle="bold"
                        android:textColor="#2E7D32"
                        android:textSize="16sp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/detailStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Pending"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#D32F2F"
                        android:layout_weight="2" />
                </LinearLayout>

                <!-- Payment Date -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Payment Date:"
                        android:textStyle="bold"
                        android:textColor="#2E7D32"
                        android:textSize="16sp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/detailPaymentDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textSize="16sp"
                        android:textColor="#33691E"
                        android:layout_weight="2" />
                </LinearLayout>

            </LinearLayout>

            <!-- PDF Generation Button -->
            <Button
                android:id="@+id/btnGeneratePDF"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/generate_bill_pdf"
                android:textAllCaps="true"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1B5E20"
                android:layout_marginTop="20dp"
                android:padding="12dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
