<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Product Card -->
        <LinearLayout
            android:id="@+id/cardContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:padding="14dp"
            android:layout_marginTop="50dp"
            android:elevation="6dp"
            android:layout_marginHorizontal="8dp"
            android:layout_marginBottom="16dp"
            android:clipToOutline="true">

            <!-- Product Image -->
            <ImageView
                android:id="@+id/imgProduct"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/buffer_load"
                android:scaleType="centerCrop"
                android:background="@drawable/rounded_white_card"
                android:clipToOutline="true" />

            <!-- Name, Price & Qty -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvPName"
                    android:text="Product Name"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="30dp"
                    android:textColor="#212121"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvPPrice"
                        android:text="Price: ₹0"
                        android:textSize="16sp"
                        android:layout_marginTop="20dp"
                        android:textColor="#424242"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:id="@+id/tvQty"
                        android:text="Qty: 1"
                        android:layout_marginTop="20dp"
                        android:textSize="16sp"
                        android:textColor="#424242"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Total, Date, Address -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="4dp"
            android:layout_marginHorizontal="8dp"
            android:layout_marginBottom="20dp"
            android:clipToOutline="true">

            <TextView
                android:id="@+id/tvTotal"
                android:text="Total: ₹0"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"
                android:layout_marginBottom="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Order Date"
                android:textColor="#616161"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvAddress"
                android:text="Delivery Address"
                android:textSize="14sp"
                android:textColor="#616161"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Order Tracking Title -->
        <TextView
            android:text="Order Tracking"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#1B5E20"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Timeline Steps -->
        <LinearLayout
            android:id="@+id/timelineContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="8dp">

            <include android:id="@+id/stepPlaced" layout="@layout/item_tracking_step"/>
            <include android:id="@+id/stepConfirmed" layout="@layout/item_tracking_step"/>
            <include android:id="@+id/stepDispatched" layout="@layout/item_tracking_step"/>
            <include android:id="@+id/stepTransit" layout="@layout/item_tracking_step"/>
            <include android:id="@+id/stepDelivered" layout="@layout/item_tracking_step"/>
        </LinearLayout>

        <!-- Cancel Button -->
        <Button
            android:id="@+id/btnCancelOrder"
            android:text="Cancel Order"
            android:backgroundTint="#F44336"
            android:textColor="#FFFFFF"
            android:layout_marginTop="20dp"
            android:layout_marginHorizontal="8dp"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- Loading -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_marginTop="20dp"
            android:layout_gravity="center"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>
</ScrollView>
