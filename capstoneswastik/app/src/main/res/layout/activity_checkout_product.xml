<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".CheckoutProduct">

    <ImageView
        android:id="@+id/imageViewProductimg"
        android:layout_width="200dp"
        android:layout_height="220dp"
        android:padding="12dp"
        android:background="@drawable/rounded_white_card"
        android:elevation="6dp"
        android:scaleType="centerCrop"
        android:layout_marginTop="100dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/img_jaggery" />

    <!-- Product Name -->
    <TextView
        android:id="@+id/textViewProductName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Pure Jaggery"
        android:textColor="@color/black"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/imageViewProductimg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Product Price -->
    <TextView
        android:id="@+id/textViewProductPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="₹ 120 / Kg"
        android:textColor="#18A125"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/textViewProductName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Quantity Input -->
    <LinearLayout
        android:id="@+id/quantityCard"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        android:background="#EFEFEF"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/textViewProductPrice"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:layout_marginEnd="12dp"
            android:text="@string/quantity"
            android:textColor="@color/black"
            android:textSize="18sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnMinus"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="−"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:background="@android:color/transparent"
                android:padding="0dp"/>

            <TextView
                android:id="@+id/textQuantity"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="1"
                android:textSize="18sp"
                android:textColor="@color/black"/>

            <Button
                android:id="@+id/btnPlus"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="+"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:background="@android:color/transparent"
                android:padding="0dp"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Total Price -->
    <TextView
        android:id="@+id/totalprice"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:layout_marginTop="16dp"
        android:background="#EFEFEF"
        android:gravity="center"
        android:text="@string/total_price_0"
        android:textColor="@color/black"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/quantityCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Next Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNext"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:layout_marginTop="24dp"
        android:text="@string/next"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        app:backgroundTint="#18D527"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/totalprice"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
