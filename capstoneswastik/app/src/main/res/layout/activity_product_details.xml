<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".Product_details">

    <!-- Product Image -->
    <ImageView
        android:id="@+id/imageViewProductimg"
        android:layout_width="200dp"
        android:layout_height="220dp"
        android:padding="12dp"
        android:background="@drawable/rounded_white_card"
        android:elevation="6dp"
        android:scaleType="centerCrop"
        app:srcCompat="@drawable/img_jaggery"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="40dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Product Name -->
    <TextView
        android:id="@+id/textViewProductName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Pure Jaggery"
        android:textColor="@color/black"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/imageViewProductimg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Price -->
    <TextView
        android:id="@+id/textViewProductPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="₹ 120 / Kg"
        android:textColor="#18A125"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/textViewProductName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Description Card -->
    <LinearLayout
        android:id="@+id/descriptionCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/rounded_white_card"
        android:padding="20dp"
        android:elevation="6dp"
        android:layout_marginTop="20dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        app:layout_constraintTop_toBottomOf="@id/textViewProductPrice"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/textViewProductDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="This is high-quality natural jaggery directly sourced from organic farms. No chemicals, preservatives, or artificial coloring."
            android:textColor="@color/black"
            android:textSize="16sp"
            android:lineSpacingExtra="6dp"/>
    </LinearLayout>

    <!-- Buy Now Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBuyNow"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:text="BUY NOW"
        android:textSize="20sp"
        android:textColor="@android:color/white"
        app:backgroundTint="#18D527"
        app:cornerRadius="12dp"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:layout_marginBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
