<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background Image -->
    <ImageView
        android:id="@+id/bgImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/background_supplier"
        android:scaleType="centerCrop"
        android:adjustViewBounds="true" />

    <!-- Foreground Scrollable Form -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:background="@drawable/form_card_bg"
            android:elevation="10dp">

            <!-- Title -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sugarcane Supplier Request"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#2E7D32"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="20dp" />

            <!-- Product Name -->
            <TextView
                android:text="Product Name"
                android:textColor="#1B5E20"
                android:textSize="16sp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <EditText
                android:id="@+id/etProductName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Sugarcane"
                android:text="Sugarcane"
                android:enabled="false"
                android:focusable="false"
                android:background="@drawable/rounded_edittext"
                android:layout_marginBottom="20dp" />

            <!-- Quantity -->
            <TextView
                android:text="Quantity Available (in tonnes or kg)"
                android:textColor="#1B5E20"
                android:textSize="16sp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <EditText
                android:id="@+id/etQuantity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter quantity (e.g., 50 tonnes)"
                android:inputType="numberDecimal"
                android:background="@drawable/rounded_edittext"
                android:layout_marginBottom="20dp" />

            <!-- Location -->
            <TextView
                android:text="Location (Village/District)"
                android:textColor="#1B5E20"
                android:textSize="16sp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <EditText
                android:id="@+id/etLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter village/city/district"
                android:inputType="text"
                android:background="@drawable/rounded_edittext"
                android:layout_marginBottom="20dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Submit Button -->
    <Button
        android:id="@+id/btnSubmitRequest"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_margin="20dp"
        android:text="SUBMIT AVAILABILITY"
        android:textColor="#FFFFFF"
        android:backgroundTint="#4CAF50"
        android:elevation="10dp" />

</RelativeLayout>


